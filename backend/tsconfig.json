{
  "compilerOptions": {
    /* === Environnement Node === */
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,

    /* === Structure du projet === */
    "rootDir": "./src",
    "outDir": "./dist",

    /* === Autres === */
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "noImplicitAny": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
