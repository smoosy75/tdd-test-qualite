{
  "compilerOptions": {
    /* === Environnement Node === */
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,

    /* === Structure du projet === */
    "rootDir": "./src",
    "outDir": "./dist",

    /* === Autres === */
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "noImplicitAny": false
  },
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node"
  },
  "lib": ["esnext"],
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
